{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "grammars": [
    {
      "name": "clojure",
      "camelcase": "Clojure",
      "scope": "source.clojure",
      "path": ".",
      "file-types": [
        "bb",
        "clj",
        "cljc",
        "cljs"
      ],
      "injection-regex": "^clojure$"
    }
  ],
  "metadata": {
    "version": "0.0.13",
    "license": "CC0-1.0",
    "description": "Clojure(Script) grammar for tree-sitter",
    "authors": [
      {
        "name": "sogaiu"
      }
    ],
    "links": {
      "repository": "https://github.com/Blockether/tree-sitter-clojure"
    }
  },
  "bindings": {
    "c": false,
    "go": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}
